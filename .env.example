# Ardeo Codex — backoffice configuration.
# Copy to `.env.local` for local dev, and set the same vars in Vercel's
# Project → Settings → Environment Variables for production.

# --- Login (required to enable editing) ---------------------------------
# The username/password you type at /admin/login.
ADMIN_USERNAME=changeme
ADMIN_PASSWORD=use-a-long-random-passphrase

# Secret used to sign the login cookie. Any long random string.
# If unset it falls back to ADMIN_PASSWORD.
SESSION_SECRET=another-long-random-string

# --- Where saves go (production) ----------------------------------------
# A GitHub token with read/write access to the codex repo's Contents.
# When set, every "Save" commits to the repo and Vercel redeploys.
# Leave UNSET locally to write straight to the content/ files instead.
GITHUB_TOKEN=
GITHUB_REPO=NemanjaTck/ardeo-codex
GITHUB_BRANCH=main

# Optional: force a backend regardless of the token ("github" | "fs").
# CONTENT_BACKEND=github
